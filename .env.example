# --- HTTP ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Redis (cache + BullMQ broker) ---
REDIS_URL=redis://localhost:6379

# --- PostgreSQL (primary relational store) ---
DATABASE_URL=postgres://dops:dops@localhost:5432/dops

# --- Idempotency guard ---
# How long a processed order's dedupe marker is retained.
IDEMPOTENCY_TTL_SECONDS=86400
# If Redis is unreachable during the dedupe check: true = accept + enqueue anyway
# (never drop a real order), false = reject with 503 so the platform retries.
IDEMPOTENCY_FAIL_OPEN=true

# --- Ingestion queue ---
QUEUE_NAME=ingestion
WORKER_CONCURRENCY=5

# --- AI Parser (optional — only needed for POST /parse) ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Model to use for order parsing. Defaults to gemini-2.0-flash if unset.
GEMINI_MODEL=gemini-2.0-flash
